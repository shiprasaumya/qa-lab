{
  "expo": {
    "name": "TestMind AI",
    "slug": "testmind-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/testmind-icon.png",
    "scheme": "testmindai",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/testmind-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/testmind-icon.png",
        "backgroundColor": "#F8FAFC"
      }
    },
    "web": {
      "favicon": "./assets/testmind-icon.png"
    },
    "plugins": ["expo-image-picker"]
  }
}
